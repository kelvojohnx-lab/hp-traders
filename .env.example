# ═══════════════════════════════════════════════════════════
#  HP TRADERS — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values
#  On Render: add these in Dashboard → Environment Variables
# ═══════════════════════════════════════════════════════════

PORT=10000

# ── DERIV ─────────────────────────────────────────────────
# 1. Register your app: https://api.deriv.com/docs/app-registration
# 2. Set OAuth Redirect URI to: https://YOUR-APP.onrender.com/api/deriv/callback
# 3. Copy the App ID below
DERIV_APP_ID=YOUR_DERIV_APP_ID
DERIV_REDIRECT_URI=https://YOUR-APP.onrender.com/api/deriv/callback

# ── MPESA (Safaricom Daraja) ───────────────────────────────
# Get credentials from: https://developer.safaricom.co.ke
# Sandbox shortcode: 174379 | Passkey below is sandbox passkey
MPESA_CONSUMER_KEY=YOUR_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://YOUR-APP.onrender.com/api/mpesa/callback

# ── ENVIRONMENT ────────────────────────────────────────────
# development = sandbox M-Pesa | production = live M-Pesa
NODE_ENV=production
